{
  "id": "supply_gap",
  "type": "SharedSlice",
  "name": "SupplyGap",
  "description": "Pinned demand-vs-supply chart: both curves and their gradient fills wipe in left→right and the two endpoint figures count up as the section scrolls. The deficit reads as the band between the curves.",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "is_hidden": {
          "type": "Boolean",
          "config": {
            "label": "Hide slice",
            "placeholder_false": "Visible",
            "placeholder_true": "Hidden",
            "default_value": false
          }
        },
        "scroll_length": {
          "type": "Number",
          "config": {
            "label": "Scroll length (vh)",
            "placeholder": "Pinned scroll distance in vh (default: 220)"
          }
        },
        "heading": {
          "type": "StructuredText",
          "config": {
            "label": "Heading",
            "placeholder": "Headline (e.g. Demand is set, but supply is uncertain.)",
            "allowTargetBlank": true,
            "single": "paragraph,strong,em"
          }
        },
        "body": {
          "type": "Text",
          "config": {
            "label": "Body",
            "placeholder": "Supporting paragraph shown beside the heading"
          }
        },
        "y_ticks": {
          "type": "Group",
          "config": {
            "label": "Y-axis ticks (low → high)",
            "fields": {
              "value": {
                "type": "Text",
                "config": { "label": "Tick", "placeholder": "e.g. 10" }
              }
            }
          }
        },
        "x_labels": {
          "type": "Group",
          "config": {
            "label": "X-axis labels (left → right)",
            "fields": {
              "value": {
                "type": "Text",
                "config": { "label": "Label", "placeholder": "e.g. 2030" }
              }
            }
          }
        },
        "demand": {
          "type": "Group",
          "config": {
            "label": "Demand endpoint (counts up)",
            "fields": {
              "label": {
                "type": "Text",
                "config": { "label": "Label", "placeholder": "e.g. DEMAND" }
              },
              "value": {
                "type": "Text",
                "config": { "label": "Value", "placeholder": "e.g. 1270" }
              }
            }
          }
        },
        "supply": {
          "type": "Group",
          "config": {
            "label": "Supply endpoint (counts up)",
            "fields": {
              "label": {
                "type": "Text",
                "config": { "label": "Label", "placeholder": "e.g. CURRENT AND DEVELOPING MINES" }
              },
              "value": {
                "type": "Text",
                "config": { "label": "Value", "placeholder": "e.g. 627" }
              }
            }
          }
        }
      },
      "items": {}
    }
  ]
}
