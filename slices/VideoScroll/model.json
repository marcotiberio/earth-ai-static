{
  "id": "video_scroll",
  "type": "SharedSlice",
  "name": "VideoScroll",
  "description": "Pinned full-bleed video/image with a headline that scrolls over it.",
  "variations": [
    {
      "id": "overlay",
      "name": "Overlay",
      "docURL": "...",
      "version": "initial",
      "description": "Pinned full-bleed background with an overlaid headline.",
      "imageUrl": "",
      "primary": {
        "video_url": {
          "type": "Link",
          "config": {
            "label": "Background video",
            "placeholder": "Upload or select a video from the Media Library",
            "select": "media"
          }
        },
        "image": {
          "type": "Image",
          "config": {
            "label": "Background image",
            "constraint": {},
            "thumbnails": []
          }
        },
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Headline",
            "allowTargetBlank": true,
            "single": "heading1,heading2,heading3,strong,em"
          }
        },
        "scrub_start": {
          "type": "Select",
          "config": {
            "label": "Scrub start",
            "placeholder": "When the scroll-scrub begins (default: full travel)",
            "options": [
              "top",
              "middle"
            ]
          }
        },
        "title_align_vertical": {
          "type": "Select",
          "config": {
            "label": "Title vertical position",
            "placeholder": "Vertical position (default: bottom)",
            "options": [
              "top",
              "center",
              "bottom"
            ],
            "default_value": "bottom"
          }
        },
        "title_align_horizontal": {
          "type": "Select",
          "config": {
            "label": "Title horizontal position",
            "placeholder": "Horizontal position (default: left)",
            "options": [
              "left",
              "center",
              "right"
            ],
            "default_value": "left"
          }
        }
      },
      "items": {}
    }
  ]
}