{
  "id": "map_targets",
  "type": "SharedSlice",
  "name": "MapTargets",
  "description": "Pinned dark scene: a WYSIWYG title with count-up metrics and a supporting paragraph beside a continental target map whose orange markers wipe in left→right on scroll. Add up to 4 stat rows.",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "is_hidden": {
          "type": "Boolean",
          "config": {
            "label": "Hide slice",
            "placeholder_false": "Visible",
            "placeholder_true": "Hidden",
            "default_value": false
          }
        },
        "scroll_length": {
          "type": "Number",
          "config": {
            "label": "Scroll length (vh)",
            "placeholder": "Pinned scroll distance in vh (default: 220)"
          }
