            "single": "paragraph,strong,em"
          }
        },
        "body": {
          "type": "Text",
          "config": {
            "label": "Body",
            "placeholder": "Supporting paragraph shown at the bottom-left"
          }
        },
        "stats": {
          "type": "Group",
          "config": {
            "label": "Stats (max 4)",
            "fields": {
              "label": {
                "type": "Text",
                "config": {
                  "label": "Title",
                  "placeholder": "e.g. New Targets"
                }
              },
              "value": {
                "type": "Text",
                "config": {
                  "label": "Number",
                  "placeholder": "e.g. 1,500 or 83% (counts up on scroll)"
                }
              }
            }
          }
        }
